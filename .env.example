# GoldTrader Pro — Variáveis de Ambiente

# Modo de operação: paper | live | backtest | signal_only
APP_MODE=paper

# Database (TimescaleDB)
DATABASE_URL=postgresql+asyncpg://goldtrader:goldtrader_dev@localhost:5432/goldtrader

# Redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

